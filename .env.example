# Copie este arquivo para .env e ajuste os valores antes de subir o projeto.
# O arquivo .env NUNCA deve ser commitado no Git (contém segredos).

# --- Banco de dados PostgreSQL ---
DB_NAME=utest_db
DB_USER=utest_user
DB_PASSWORD=utest_password

# --- JWT ---
# Gere uma chave longa e aleatoria, por exemplo com: openssl rand -base64 48
JWT_SECRET=troque-esta-chave-por-uma-bem-longa-e-aleatoria-antes-de-usar-em-producao
JWT_EXPIRATION_MS=86400000

# --- Regra de negocio do aluno ---
ALUNO_DOMINIO_INSTITUCIONAL=@edu.udesc.br

# --- CORS ---
# Endereco de onde o front-end (Nginx) é servido
CORS_ALLOWED_ORIGINS=http://localhost:8081

# --- Area administrativa (apenas para demonstracao, sem integracao com id.udesc) ---
ADMIN_SECRET=utest-admin-2026
